COMPOSE_PROJECT_NAME=farmacia

# Red Docker y contenedor de BD de hce-core
# (usados por instalar.sh para conectar farm-api a esa red después de levantarlo)
HCE_NETWORK_NAME=consultorio_default
HCE_DB_CONTAINER=consultorio-db

# Credenciales de la base de datos (mismas que hce-core)
DB_USER=hce
DB_PASSWORD=your-db-password
DB_NAME=hce_provider

# La DATABASE_URL usa el nombre del contenedor de BD de hce-core
DATABASE_URL=postgresql://hce:your-db-password@consultorio-db:5432/hce_provider?sslmode=disable
JWT_SECRET=your-jwt-secret-base64
PORT=8010

VITE_API_URL=http://localhost:8010
UI_PORT=8080
APP_TZ=America/Bogota

DOCKER_API_PORT=8010
DOCKER_ALLOWED_ORIGIN=http://localhost:8080
DOCKER_VITE_API_URL=http://localhost:8010

# Impresora térmica — nombre del queue en CUPS (dejar vacío si no se usa)
PRINTER_TERMICA=
